# ============================================================
# Daytona on Railway — environment variable reference
# Copy these into your Railway service's Variables tab.
# Railway reference syntax: ${{ServiceName.VAR_NAME}}
# ============================================================

# -- Postgres (Railway plugin, service name: Postgres) -------
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_USERNAME=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}
DB_DATABASE=${{Postgres.PGDATABASE}}

# -- Redis (Railway plugin, service name: Redis) -------------
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}

# -- MinIO (custom service, service name: Minio) -------------
# Uses Railway private networking — do NOT expose MinIO's S3 port publicly.
S3_ENDPOINT=http://${{Minio.RAILWAY_PRIVATE_DOMAIN}}:9000
S3_ACCESS_KEY=${{Minio.MINIO_ROOT_USER}}
S3_SECRET_KEY=${{Minio.MINIO_ROOT_PASSWORD}}
S3_BUCKET=daytona
S3_REGION=us-east-1

# -- Public URLs (auto-populated by Railway) -----------------
DASHBOARD_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}/dashboard
DASHBOARD_BASE_API_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}

# -- Security ------------------------------------------------
# REQUIRED: generate with: openssl rand -hex 16
# NEVER commit real values. NEVER reuse across environments.
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING
ENCRYPTION_SALT=CHANGE_ME_32_CHAR_RANDOM_STRING

# -- Runtime -------------------------------------------------
RUN_MIGRATIONS=true
PORT=3000
NODE_ENV=production

# -- SMTP (optional — leave blank to disable email) ----------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# -- Quota defaults (optional) -------------------------------
# DEFAULT_QUOTA_CPU=2
# DEFAULT_QUOTA_MEMORY=2048
# DEFAULT_QUOTA_DISK=10
