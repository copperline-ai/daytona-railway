# Local docker-compose config for the runner + registry.
#
# The values marked "↔ Railway" MUST match the corresponding Daytona API env
# vars set on the Railway `daytona` service (see README) — that's how the API
# authenticates to this runner and registry. Nothing here touches the DB.

# ── Daytona control plane ───────────────────────────────────────────────────
DAYTONA_API_URL=https://daytona-production-4ed5.up.railway.app/api

# Shared runner token.  ↔ Railway DEFAULT_RUNNER_API_KEY
# Generate: openssl rand -hex 32
DAYTONA_RUNNER_TOKEN=change-me-openssl-rand-hex-32

# ── Tunnel hostnames (your named Cloudflare tunnel) ─────────────────────────
# Stable hostnames on a domain you control. No scheme on the host vars.
PUBLIC_RUNNER_URL=https://runner.example.com     # ↔ Railway DEFAULT_RUNNER_API_URL / PROXY_URL
PUBLIC_REGISTRY_HOST=registry.example.com         # ↔ Railway INTERNAL/TRANSIENT_REGISTRY_URL host

# ── Local registry basic-auth ────────────────────────────────────────────────
# ↔ Railway INTERNAL_REGISTRY_ADMIN / TRANSIENT_REGISTRY_ADMIN  (REGISTRY_USER)
# ↔ Railway INTERNAL_REGISTRY_PASSWORD / TRANSIENT_REGISTRY_PASSWORD (REGISTRY_PASS)
REGISTRY_USER=daytona
REGISTRY_PASS=change-me

# ── Object storage (Daytona MinIO) — snapshot backups ───────────────────────
AWS_ENDPOINT_URL=https://minio-production-3b7b.up.railway.app
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<minio-root-user>
AWS_SECRET_ACCESS_KEY=<minio-root-password>
AWS_DEFAULT_BUCKET=daytona

# ── Runner behavior ──────────────────────────────────────────────────────────
ENVIRONMENT=development
RESOURCE_LIMITS_DISABLED=true
INTER_SANDBOX_NETWORK_ENABLED=false
